{
    "name": "sartin/heirloom",
    "description": "Painting giveaway gallery",
    "type": "project",
    "license": "Apache-2.0",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-fileinfo": "*",
        "ext-mbstring": "*",
        "league/oauth2-client": "^2.7",
        "league/oauth2-google": "^4.0",
        "phpmailer/phpmailer": "^6.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpspec/phpspec": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "Heirloom\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Heirloom\\Tests\\": "tests/"
        }
    },
    "config": {
        "process-timeout": 120
    },
    "scripts": {
        "test": "@php vendor/bin/phpunit",
        "spec": "@php vendor/bin/phpspec run --format=pretty --no-interaction",
        "check": ["@test", "@spec"]
    }
}
